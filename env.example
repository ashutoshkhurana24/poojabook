# PostgreSQL connection string
# For local: postgresql://user:password@localhost:5432/poojabook
# For Vercel: provided by Vercel Postgres integration
DATABASE_URL="postgresql://user:password@localhost:5432/poojabook"

# JWT Secret - use a strong random string (e.g. openssl rand -hex 32)
JWT_SECRET=""

# Admin/setup secrets - use strong random strings for each
ADMIN_SETUP_SECRET=""
SETUP_SECRET=""
SEED_SECRET=""

# Firebase (client-side - NEXT_PUBLIC_ prefix required)
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=""
NEXT_PUBLIC_FIREBASE_PROJECT_ID=""
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=""
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=""
NEXT_PUBLIC_FIREBASE_APP_ID=""
NEXT_PUBLIC_FIREBASE_VAPID_KEY=""

# SMS provider (Twilio or Fast2SMS)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# Fast2SMS (alternative to Twilio)
FAST2SMS_API_KEY=""

# Firebase Admin SDK (server-side, for sending push notifications)
# Download service account JSON from Firebase Console → Project Settings → Service Accounts
# Then copy projectId, clientEmail, and privateKey from the JSON
FIREBASE_ADMIN_PROJECT_ID=""
FIREBASE_ADMIN_CLIENT_EMAIL=""
FIREBASE_ADMIN_PRIVATE_KEY=""   # paste the full private key including -----BEGIN/END----- lines

# Razorpay (payment)
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
NEXT_PUBLIC_RAZORPAY_KEY_ID=""
